VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Opcional — erros do frontend no Sentry (projeto browser)
VITE_SENTRY_DSN=
# URL publica do app (Railway: https://seu-servico.up.railway.app)
VITE_APP_URL=http://localhost:8080
# Google reCAPTCHA v2 CHECKBOX (login). NAO use chave v3 ou "invisivel".
# Dev/local: omita — reCAPTCHA fica desligado no login.
# Producao: https://www.google.com/recaptcha/admin → tipo "Caixa de selecao" (v2)
# Domínios: localhost, 127.0.0.1, seu-dominio.com (sem https://)
VITE_RECAPTCHA_SITE_KEY=
# Par da site key — apenas no Supabase (nunca no frontend):
# supabase secrets set RECAPTCHA_SECRET_KEY=sua_secret_key
# Criptografia AES das credenciais UAZAPI armazenadas no Postgres (service_role / Edge Functions).
# Gere com: openssl rand -base64 32
# Rotacao: nova chave exige reconfigurar instancias UAZAPI no app (ver docs/SUPABASE_UAZAPI_DEPLOY.md).
APP_ENCRYPTION_KEY=
# Mesmo valor em supabase secrets; use no header x-cron-secret dos jobs agendados (poll, campanhas, follow-up).
CRON_SECRET=

# Copie para scripts/migrate-to-selfhosted-supabase.env e preencha.
# Nao commite o arquivo real.

# URL publica usada pelo frontend e pelos smoke tests.
SUPABASE_PUBLIC_URL=https://supabasewchat.eversync.space

# Conexao Postgres acessivel a partir desta maquina.
# Para VPS, normalmente use um tunel SSH:
#   ssh -N -L 65432:127.0.0.1:5432 usuario@seu-servidor
# e entao:
#   SUPABASE_DB_URL=postgresql://postgres:SENHA@127.0.0.1:65432/postgres?sslmode=disable
SUPABASE_DB_URL=

# Destino SSH onde esta o docker-compose do Supabase self-hosted.
VPS_SSH_TARGET=usuario@seu-servidor
VPS_SUPABASE_DIR=/root/supabase/docker
VPS_FUNCTIONS_DIR=/root/supabase/docker/volumes/functions
VPS_FUNCTIONS_SERVICE=supabase_functions

# Secrets/custom envs usadas pelas Edge Functions.
# No self-hosted, essas variaveis precisam estar no container `functions`.
# O script envia um arquivo .env.functions, mas o docker-compose precisa referencia-lo
# em `functions.env_file` ou equivalente.
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
VOYAGE_API_KEY=
RESEND_API_KEY=
N8N_SERVICE_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_ALLOW_TEST_SECRET=
IPINFO_TOKEN=
CRON_SECRET=
APP_SITE_URL=
PUBLIC_APP_URL=
MARKETING_EMAIL_FROM=
